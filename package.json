{
  "name": "api-gateway-routing-research",
  "version": "1.0.0",
  "description": "Analyzing the Complexity of Request Routing Algorithms in Microservices Architecture",
  "scripts": {
    "start": "docker compose up --build",
    "stress": "node scripts/stressTest.js",
    "export:csv": "node scripts/export-csv.js",
    "phase3": "node scripts/stressTest.js && node scripts/export-csv.js",
    "test:read": "artillery run load-tests/artillery-read-heavy.yml --output reports/report-read-heavy.json",
    "test:compute": "artillery run load-tests/artillery-compute-heavy.yml --output reports/report-compute-heavy.json",
    "test:mixed": "artillery run load-tests/artillery-mixed.yml --output reports/report-mixed.json",
    "test:all": "npm run test:read && npm run test:compute && npm run test:mixed && node scripts/generate-synthesis-report.js",
    "report": "node scripts/generate-synthesis-report.js",
    "docker:stress": "docker compose --profile tools run --rm stress",
    "docker:phase3": "docker compose --profile tools run --rm phase3",
    "docker:export": "docker compose --profile tools run --rm export-csv",
    "docker:test:read": "docker compose --profile tools run --rm test-read",
    "docker:test:compute": "docker compose --profile tools run --rm test-compute",
    "docker:test:mixed": "docker compose --profile tools run --rm test-mixed"
  },
  "devDependencies": {
    "artillery": "^2.0.21"
  }
}
